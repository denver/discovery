# --- Required ---

# YouTube Data API v3 key. See README for how to obtain one.
# Never exposed to clients; server-side only.
YOUTUBE_API_KEY=

# Path to the collection file to serve (file mode).
DISCOVERY_COLLECTION_PATH=./collections/example.json

# --- Optional ---

# HTTP port (default 8080).
PORT=8080

# Local cache file for fetched YouTube metadata (file mode).
# DISCOVERY_CACHE_PATH=./.discovery-cache.json

# Enable database mode by setting a PostgreSQL connection string.
# (Namespaced deliberately: an ambient DATABASE_URL from another project
# never flips the mode.)
# When unset, Discovery runs in file mode (no database required).
# DISCOVERY_DATABASE_URL=postgres://discovery:discovery@localhost:5432/discovery?sslmode=disable

# Refresh interval for the built-in scheduler (e.g. 6h, 30m).
# Overrides the collection file's refreshInterval when set.
# DISCOVERY_REFRESH_INTERVAL=6h

# Require "Authorization: Bearer <token>" on POST /api/v1/sync.
# Unset = no auth (local development). Set on any hosted deployment.
# Generate with: openssl rand -hex 32
# DISCOVERY_ADMIN_TOKEN=
